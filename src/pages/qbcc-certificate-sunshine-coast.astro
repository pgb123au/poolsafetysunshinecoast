  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long does a QBCC pool safety certificate last on the Sunshine Coast?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Two years for non-shared pools (a typical Maroochydore or Buderim backyard pool) and one year for shared pools at units, motels and short-stay properties. The certificate is tied to the pool, not the owner, so if the property sells inside that window the buyer inherits the remaining term."
      }
    },
    {
      "@type": "Question",
      "name": "What is a Form 36 and when do I need one?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A Form 36 is the Notice of No Pool Safety Certificate. The seller lodges it with the QBCC before settlement when no current certificate is in place. It puts the buyer on notice that they have 90 days from settlement to obtain a compliant certificate, and a copy must be given to the buyer and any tenants at the property."
      }
    },
    {
      "@type": "Question",
      "name": "Who can issue a QBCC pool safety certificate on the Sunshine Coast?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Only a licensed QBCC Pool Safety Inspector. Our licence number is printed on every Form 23 certificate we issue along with the inspection date, the pool's QBCC pool register ID and the standard the pool was tested against (Pool Safety Standard MP 3.4 / QDC MP 3.4)."
      }
    },
    {
      "@type": "Question",
      "name": "What are the most common reasons a Sunshine Coast pool fails inspection?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Self-closing gate hinges that have lost tension, climbable objects inside the 900mm non-climbable zone (pot plants, BBQs, pool pumps), missing or sun-faded CPR signage, gaps wider than 100mm at the bottom of fence panels, and door alarms that no longer arm on pool-facing windows in older Mooloolaba and Caloundra homes."
      }
    },
    {
      "@type": "Question",
      "name": "How much does a QBCC pool safety inspection cost in Sunshine Coast?",
      "acceptedAnswer": {
